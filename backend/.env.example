# ─── Server ───
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ─── Database (PostgreSQL) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aone_siakad
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───
JWT_VENDOR_SECRET=change-me-vendor-secret-key-32chars
JWT_CAMPUS_SECRET=change-me-campus-secret-key-32chars
JWT_ACCESS_EXPIRES=8h
JWT_REFRESH_EXPIRES=30d

# ─── Object Storage (Cloudflare R2 / S3-compatible) ───
# Untuk MinIO lokal: S3_ENDPOINT=http://localhost:9000, S3_FORCE_PATH_STYLE=true
# Untuk Cloudflare R2: S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aone-assets
S3_PUBLIC_URL=http://localhost:9000/aone-assets
S3_FORCE_PATH_STYLE=true

# ─── MinIO / S3 (legacy - gunakan S3_* di atas) ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=aone-documents
MINIO_BUCKET_ASSETS=aone-assets
MINIO_USE_SSL=false

# ─── Midtrans ───
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ─── SMTP ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aone-project.com

# ─── PDDIKTI ──
PDDIKTI_API_BASE=https://api.klaster.layanan.id/v1
PDDIKTI_API_KEY=

# ─── OJS ───
OJS_URL=http://localhost/ojs-v3
OJS_API_KEY=
OJS_CONTEXT=
OJS_API_TIMEOUT=10000

# ─── AI (OpenAI) ───
OPENAI_API_KEY=sk-your-openai-api-key
