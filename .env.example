# ---- Server ----
NODE_ENV=production
PORT=10000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aone_siakad
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Or use DATABASE_URL (overrides individual DB_* vars)
# DATABASE_URL=postgresql://user:password@host:5432/aone_siakad

# ---- JWT ----
JWT_VENDOR_SECRET=change-this-to-random-secret
JWT_CAMPUS_SECRET=change-this-to-random-secret
JWT_ACCESS_EXPIRES=8h
JWT_REFRESH_EXPIRES=30d

# ---- Redis (optional) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- MinIO (optional, file storage) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=aone-documents
MINIO_BUCKET_ASSETS=aone-assets
MINIO_USE_SSL=false

# ---- Midtrans (optional, payment gateway) ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- SMTP (optional, email) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aone-campus.com

# ---- PDDIKTI (optional, integration) ----
PDDIKTI_API_BASE=https://api.klaster.layanan.id/v1
PDDIKTI_API_KEY=

# ---- OJS (optional, journal integration) ----
OJS_URL=http://localhost/ojs-v3
OJS_API_KEY=
OJS_CONTEXT=
OJS_API_TIMEOUT=10000
